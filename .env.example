# VPC PostgreSQL 접속 정보
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 입력하세요
# cp .env.example .env

DB_HOST=        # VPC 공인 IP (docker ps 또는 VPC 콘솔에서 확인)
DB_PORT=        # Docker 호스트 포트 (docker ps의 PORTS 앞 번호, 기본 5432)
DB_NAME=        # PostgreSQL 데이터베이스 이름 (예: vod_db)
DB_USER=        # PostgreSQL 계정 (예: postgres)
DB_PASSWORD=    # PostgreSQL 비밀번호
