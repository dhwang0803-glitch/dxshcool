# VOD Recommendation — 환경변수 템플릿
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 입력하세요.
# cp .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요.

# ── PostgreSQL (VPC) ──────────────────────────────────────
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# ── TMDB API ──────────────────────────────────────────────
TMDB_API_KEY=

# ── KMDB API ──────────────────────────────────────────────
KMDB_API_KEY=

# ── 공공데이터포털 (영상물등급위원회) ─────────────────────
DATA_GO_API_KEY=

# ── Naver API (선택) ──────────────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── Ollama (로컬) ─────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=exaone3.5:7.8b

# ── 파일 경로 ─────────────────────────────────────────────
# 트레일러 저장 경로 (VOD_Embedding 브랜치)
TRAILERS_DIR=
