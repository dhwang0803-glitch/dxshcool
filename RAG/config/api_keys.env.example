# RAG Pipeline API Keys
# 복사 후 api_keys.env로 저장 (git 제외 필수)

# TMDB (The Movie Database) — https://www.themoviedb.org/settings/api
# 무료 가입 후 "API 키(v3 auth)" 발급
TMDB_API_KEY=your_tmdb_v3_api_key_here

# KMDB (한국영상자료원) — https://www.kmdb.or.kr/api/apiDetail
# 회원가입 후 API 신청 (무료, 승인 필요)
KMDB_API_KEY=your_kmdb_api_key_here

# AI-Hub (문화콘텐츠 스토리 데이터) — 로컬 파일 방식, API 키 불필요
# https://aihub.or.kr 에서 데이터셋 다운로드 후 RAG/data/aihub_cultural.json 에 저장

# Ollama (LLM 폴백)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=exaone3.5:7.8b
